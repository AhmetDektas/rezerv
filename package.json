{
  "name": "rezerv",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "type-check": "turbo type-check",
    "db:generate": "pnpm --filter @rezerv/db generate",
    "db:migrate": "pnpm --filter @rezerv/db migrate:dev",
    "db:push": "pnpm --filter @rezerv/db push",
    "db:studio": "pnpm --filter @rezerv/db studio"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
